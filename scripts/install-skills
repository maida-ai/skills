#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
usage: scripts/install-skills [--dry-run] [--fail-fast] [--replace] [--target codex|claude] [--dest DIR] <family|family/skill>

Examples:
  scripts/install-skills developer
  scripts/install-skills developer --replace
  scripts/install-skills --target claude developer
  scripts/install-skills developer/split-pr-stack
  scripts/install-skills --fail-fast developer
  scripts/install-skills --dest /tmp/agent-skills --dry-run developer
USAGE
}

DRY_RUN=false
FAIL_FAST=false
REPLACE=false
TARGET_AGENT="codex"
DEST_DIR=""
TARGET=""

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --fail-fast)
      FAIL_FAST=true
      shift
      ;;
    --replace)
      REPLACE=true
      shift
      ;;
    --target)
      TARGET_AGENT="${2:-}"
      if [[ -z "$TARGET_AGENT" || "$TARGET_AGENT" == --* ]]; then
        echo "error: --target requires codex or claude" >&2
        exit 1
      fi
      shift 2
      ;;
    --dest)
      DEST_DIR="${2:-}"
      if [[ -z "$DEST_DIR" || "$DEST_DIR" == --* ]]; then
        echo "error: --dest requires a directory" >&2
        exit 1
      fi
      shift 2
      ;;
    --help)
      usage
      exit 0
      ;;
    --*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$TARGET" ]]; then
        echo "error: only one family or skill target may be provided" >&2
        usage >&2
        exit 1
      fi
      TARGET="$1"
      shift
      ;;
  esac
done

if [[ -z "$TARGET" ]]; then
  usage
  exit 0
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "$TARGET_AGENT" in
  codex)
    INSTALL_ROOT="${DEST_DIR:-${CODEX_SKILLS_DIR:-$HOME/.agents/skills}}"
    ;;
  claude)
    INSTALL_ROOT="${DEST_DIR:-${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}}"
    ;;
  *)
    echo "error: --target must be codex or claude" >&2
    exit 1
    ;;
esac

collect_skills() {
  local target="$1"
  local source="$REPO_ROOT/$target"

  if [[ -f "$source/SKILL.md" ]]; then
    printf '%s\n' "$source"
    return
  fi

  if [[ -d "$source" ]]; then
    find "$source" -mindepth 2 -maxdepth 2 -name SKILL.md -print \
      | sed 's#/SKILL.md$##' \
      | sort
    return
  fi

  echo "error: no such family or skill: $target" >&2
  exit 1
}

mapfile -t SKILLS < <(collect_skills "$TARGET")

if [[ "${#SKILLS[@]}" -eq 0 ]]; then
  echo "error: no skills found under $TARGET" >&2
  exit 1
fi

if [[ "$DRY_RUN" == false ]]; then
  mkdir -p "$INSTALL_ROOT"
fi

for skill_dir in "${SKILLS[@]}"; do
  skill_name="$(basename "$skill_dir")"
  destination="$INSTALL_ROOT/$skill_name"

  if [[ "$DRY_RUN" == true ]]; then
    if [[ -e "$destination" && "$FAIL_FAST" == true ]]; then
      printf 'would fail %s -> %s (already installed)\n' "$skill_dir" "$destination"
    elif [[ -e "$destination" && "$REPLACE" == true ]]; then
      printf 'would replace %s -> %s\n' "$skill_dir" "$destination"
    elif [[ -e "$destination" ]]; then
      printf 'would skip %s -> %s (already installed)\n' "$skill_dir" "$destination"
    else
      printf 'would install %s -> %s\n' "$skill_dir" "$destination"
    fi
    continue
  fi

  if [[ -e "$destination" && "$FAIL_FAST" == true ]]; then
    echo "error: $destination already exists" >&2
    exit 1
  fi

  if [[ -e "$destination" && "$REPLACE" == false ]]; then
    printf 'skipped %s -> %s (already installed)\n' "$skill_name" "$destination"
    continue
  fi

  if [[ -e "$destination" ]]; then
    rm -rf "$destination"
    cp -R "$skill_dir" "$destination"
    printf 'replaced %s -> %s\n' "$skill_name" "$destination"
  else
    cp -R "$skill_dir" "$destination"
    printf 'installed %s -> %s\n' "$skill_name" "$destination"
  fi
done
